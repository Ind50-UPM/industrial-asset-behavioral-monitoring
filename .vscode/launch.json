{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Model_A: Train Random Forest",
            "type": "debugpy",
            "request": "launch",
            "module": "iabm.main",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/src/Model_A",
            "args": [
                "--mode", "train",
                "--algo", "rf",
                "--data-ana", "${workspaceFolder}/data/analogicas_nonans.parquet",
                "--data-dig", "${workspaceFolder}/data/digitales.parquet",
                "--start", "2022-01-18 00:00:00",
                "--end", "2022-02-18 00:00:00",
                "--model-out", "${workspaceFolder}/src/models/Model_A/analogicas_nonans.parquet_RF.joblib",
                "--pred-out", "${workspaceFolder}/src/predictions/Model_A",
                "--lang", "es"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src/Model_A"
            }
        },
        {
            "name": "Model_A: Train XGBoost",
            "type": "debugpy",
            "request": "launch",
            "module": "iabm.main",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/src/Model_A",
            "args": [
                "--mode", "train",
                "--algo", "xgb",
                "--data-ana", "${workspaceFolder}/data/analogicas_nonans.parquet",
                "--data-dig", "${workspaceFolder}/data/digitales.parquet",
                "--start", "2022-01-18 00:00:00",
                "--end", "2022-02-18 00:00:00",
                "--model-out", "${workspaceFolder}/src/models/Model_A/analogicas_nonans.parquet_XGB.joblib",
                "--pred-out", "${workspaceFolder}/src/predictions/Model_A",
                "--lang", "es"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src/Model_A"
            }
        },
        {
            "name": "Model_A: Predict Random Forest",
            "type": "debugpy",
            "request": "launch",
            "module": "iabm.main",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/src/Model_A",
            "args": [
                "--mode", "predict",
                "--algo", "rf",
                "--data-ana", "${workspaceFolder}/data/analogicas_nonans.parquet",
                "--start", "2022-02-21 00:00:00",
                "--end", "2022-02-22 00:00:00",
                "--model-out", "${workspaceFolder}/src/models/Model_A/analogicas_nonans.parquet_RF.joblib",
                "--pred-out", "${workspaceFolder}/src/predictions/Model_A",
                "--lang", "es"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src/Model_A"
            }
        },
        {
            "name": "Model_A: Predict XGBoost",
            "type": "debugpy",
            "request": "launch",
            "module": "iabm.main",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/src/Model_A",
            "args": [
                "--mode", "predict",
                "--algo", "xgb",
                "--data-ana", "${workspaceFolder}/data/analogicas_nonans.parquet",
                "--start", "2022-02-21 00:00:00",
                "--end", "2022-02-22 00:00:00",
                "--model-out", "${workspaceFolder}/src/models/Model_A/analogicas_nonans.parquet_XGB.joblib",
                "--pred-out", "${workspaceFolder}/src/predictions/Model_A",
                "--lang", "es"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src/Model_A"
            }
        },
        {
            "name": "Model_A: Evaluate RF vs XGBoost",
            "type": "debugpy",
            "request": "launch",
            "module": "iabm.main",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/src/Model_A",
            "args": [
                "--mode", "evaluate",
                "--data-ana", "${workspaceFolder}/data/analogicas_nonans.parquet",
                "--data-dig", "${workspaceFolder}/data/digitales.parquet",
                "--start", "2022-02-21 00:00:00",
                "--end", "2022-02-22 00:00:00",
                "--model-paths",
                "${workspaceFolder}/src/models/Model_A/analogicas_nonans.parquet_RF.joblib",
                "${workspaceFolder}/src/models/Model_A/analogicas_nonans.parquet_XGB.joblib",
                "--pred-out", "${workspaceFolder}/src/predictions/Model_A",
                "--lang", "es"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src/Model_A"
            }
        },
        {
            "name": "Model_B: Sequence Analysis",
            "type": "debugpy",
            "request": "launch",
            "module": "iabm_behavior.main",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/src/Model_B",
            "args": [
                "--input", "${workspaceFolder}/src/predictions/Model_A/predictions_analogicas_nonans.parquet_RF.xlsx",
                "--output-dir", "${workspaceFolder}/src/predictions/Model_B",
                "--lang", "es",
                "--smooth-short-runs",
                "--min-duration-seconds", "1.0",
                "--min-samples", "1"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src/Model_B"
            }
        },
        {
            "name": "Model_B: Compare Against Nominal",
            "type": "debugpy",
            "request": "launch",
            "module": "iabm_behavior.main",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/src/Model_B",
            "args": [
                "--input", "${workspaceFolder}/src/predictions/Model_A/predictions_analogicas_nonans.parquet_RF.xlsx",
                "--nominal-input", "${workspaceFolder}/src/predictions/Model_A/predictions_analogicas_nonans.parquet_XGB.xlsx",
                "--output-dir", "${workspaceFolder}/src/predictions/Model_B",
                "--lang", "es",
                "--smooth-short-runs",
                "--min-duration-seconds", "1.0",
                "--min-samples", "1",
                "--anomaly-threshold", "1.0"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src/Model_B"
            }
        },
        {
            "name": "Model_C: Semantic Interpretation",
            "type": "debugpy",
            "request": "launch",
            "module": "iabm_semantics.main",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/src/Model_C",
            "args": [
                "--input", "${workspaceFolder}/src/predictions/Model_B/active_sequences.xlsx",
                "--output-dir", "${workspaceFolder}/src/predictions/Model_C",
                "--lang", "es"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src/Model_C"
            }
        },
        {
            "name": "Model_C: Semantic Interpretation With Comparison",
            "type": "debugpy",
            "request": "launch",
            "module": "iabm_semantics.main",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/src/Model_C",
            "args": [
                "--input", "${workspaceFolder}/src/predictions/Model_B/active_sequences.xlsx",
                "--comparison-input", "${workspaceFolder}/src/predictions/Model_B/sequence_comparison.xlsx",
                "--output-dir", "${workspaceFolder}/src/predictions/Model_C",
                "--lang", "es"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src/Model_C"
            }
        }
    ]
}
