msgid "Behavioral sequence analysis for industrial state timelines"
msgstr "Análisis de secuencias comportamentales para cronologías de estados industriales"

msgid "Path to the state timeline file generated by Model_A or digital labeling."
msgstr "Ruta al archivo de cronología de estados generado por Model_A o por el etiquetado digital."

msgid "Optional nominal reference timeline used for anomaly comparison."
msgstr "Cronología nominal de referencia opcional utilizada para la comparación de anomalías."

msgid "Directory where Model_B reports will be written."
msgstr "Directorio donde se escribirán los informes de Model_B."

msgid "Interface language."
msgstr "Idioma de la interfaz."

msgid "State column to analyze."
msgstr "Columna de estado a analizar."

msgid "Apply smoothing to transient short runs before sequence extraction."
msgstr "Aplicar suavizado a runs transitorios cortos antes de extraer secuencias."

msgid "Maximum duration treated as a transient run."
msgstr "Duración máxima tratada como run transitorio."

msgid "Maximum sample count treated as a transient run."
msgstr "Número máximo de muestras tratado como run transitorio."

msgid "Threshold applied to the anomaly score when nominal comparison is enabled."
msgstr "Umbral aplicado a la puntuación de anomalía cuando la comparación nominal está activada."

msgid "State-run report saved to: {}"
msgstr "Informe de runs de estado guardado en: {}"

msgid "Active-sequence report saved to: {}"
msgstr "Informe de secuencias activas guardado en: {}"

msgid "Sequence-word summary saved to: {}"
msgstr "Resumen de palabras de secuencia guardado en: {}"

msgid "Sequence-comparison report saved to: {}"
msgstr "Informe de comparación de secuencias guardado en: {}"
